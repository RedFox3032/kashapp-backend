PORT=3000
JWT_SECRET=replace-with-a-strong-random-secret
APP_DEBUG=true

# PostgreSQL — required for production (Render uses this)
# Create a PostgreSQL DB on Render: Dashboard → New → PostgreSQL
# Then paste the "Internal Database URL" here
DATABASE_URL=postgresql://user:password@host:5432/dbname

# SendGrid — for sending OTP emails (HTTP API, works on Render)
# Sign up at https://sendgrid.com (free: 100 emails/day)
# Create API key at https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.xxxxx
SENDGRID_FROM=mohmmed2001.alghol2001@gmail.com
